{
    "compilerOptions": {
        "target": "es2020",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "module": "commonjs",
        "moduleResolution": "Node",
        "ignoreDeprecations": "6.0",
        "lib": ["es2020"],
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "./src",
        "outDir": "./lib/esm",
        "sourceMap": true,
        "declaration": true
    },
    "include": ["src/**/*.ts"]
}